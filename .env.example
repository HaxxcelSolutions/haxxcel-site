# ---------------------------------------------------------------------------
# Copy this file to ".env.local" and fill in the values.
# Restart the dev server after changing env values.
# ---------------------------------------------------------------------------

# Port the app listens on (default 4000, NOT 3000).
PORT=4000
# Host port Docker maps to (see docker-compose.yml).
HOST_PORT=4000

# Public site URL (used for SEO: sitemap, robots, structured data)
NEXT_PUBLIC_SITE_URL=https://www.haxxcelsolutions.com

# Google Analytics 4 Measurement ID (looks like G-XXXXXXXXXX). Leave empty to disable.
NEXT_PUBLIC_GA_ID=

# Contact form email delivery (Resend — https://resend.com)
RESEND_API_KEY=
CONTACT_TO_EMAIL=contact@haxxcelsolutions.com
CONTACT_FROM_EMAIL=noreply@haxxcelsolutions.com
